# Port selection for the Express backend server
PORT=5000

# MongoDB Connection String (Atlas cluster URI or local MongoDB URL)
MONGO_URL=mongodb://localhost:27017/ai_bgm

# Secret key for JWT signature hashing (use a secure random string)
JWT_SECRET=your_jwt_secret_key_here

# Google Gemini API Key for AI Analysis (flash model access)
GEMINI_API_KEY=your_gemini_api_key_here
